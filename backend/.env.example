# Use your Gemini API key here.
# OPENAI_API_KEY is supported as requested in spec and treated as fallback.
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_MODEL=gemini-2.0-flash
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
# Optional: override the default model (defaults to eleven_multilingual_v2)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/tef_reading
JWT_SECRET=change_me
